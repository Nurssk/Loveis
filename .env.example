# Firebase web config for the BirGe app.
#
# Copy this file to `.env.local` and paste in your project's values from the
# Firebase console: Project settings → General → "Your apps" → Web app → SDK setup.
#
# These EXPO_PUBLIC_* vars are inlined into the client bundle and are safe to
# expose — Firebase access is enforced by Firestore security rules, not by the
# secrecy of the config. `.env.local` is gitignored; this `.env.example` is the
# committed template.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
